# Server
PORT=8787
NODE_ENV=development

# Provider routing: auto | mock
AI_PROVIDER_MODE=auto
TTS_PROVIDER=auto

# MiniMax OpenAI-compatible text endpoint. Do not put real keys in Git.
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_BASE_URL=https://minnimax.chat/v1
MINIMAX_CHAT_MODEL=MiniMax-M2.7-highspeed

# MiniMax TTS/image/video endpoints vary by account and product line.
MINIMAX_TTS_BASE_URL=https://api.minimax.chat/v1
MINIMAX_GROUP_ID=your_group_id_here
MINIMAX_TTS_VOICE_ID=male-qn-qingse
MINIMAX_IMAGE_ENDPOINT=https://api.minimax.chat/v1/image_generation
MINIMAX_VIDEO_ENDPOINT=https://api.minimax.chat/v1/video_generation

# Volcengine Ark / Doubao. Fill endpoint id, not a plain model name, when using Ark.
ARK_API_KEY=your_ark_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=your_doubao_endpoint_id_here
ARK_VISION_MODEL=your_doubao_vision_endpoint_id_here
ARK_IMAGE_MODEL=your_seedream_endpoint_id_here
ARK_VIDEO_MODEL=your_seedance_endpoint_id_here

# Recommended for child-friendly TTS: Aliyun Bailian Qwen-TTS.
DASHSCOPE_API_KEY=your_dashscope_key_here
ALIYUN_TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_TTS_MODEL=qwen3-tts-flash
ALIYUN_TTS_VOICE=Mochi
ALIYUN_TTS_LANGUAGE=Chinese

# Optional Doubao/Volcengine TTS.
VOLC_TTS_APP_ID=your_volc_tts_app_id_here
VOLC_TTS_ACCESS_TOKEN=your_volc_tts_access_token_here
VOLC_TTS_CLUSTER=volcano_tts
VOLC_TTS_VOICE_TYPE=your_child_friendly_voice_type_here
